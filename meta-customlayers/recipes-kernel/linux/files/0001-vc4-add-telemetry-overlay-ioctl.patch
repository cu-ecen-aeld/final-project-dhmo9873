diff --git a/drivers/gpu/drm/vc4/vc4_plane.c b/drivers/gpu/drm/vc4/vc4_plane.c
index aabbcc0..4455667 100644
--- a/drivers/gpu/drm/vc4/vc4_plane.c
+++ b/drivers/gpu/drm/vc4/vc4_plane.c
@@ -950,6 +950,28 @@ struct drm_plane *vc4_plane_init(struct drm_device *dev,
  * ... existing vc4_plane_init code ...
  */
 
+/**
+ * vc4_get_telemetry_plane - Find the reserved telemetry overlay plane.
+ * @dev: DRM device
+ *
+ * Iterates the plane list and returns the overlay plane at index
+ * VC4_TELEMETRY_PLANE_INDEX (1). This plane is reserved at driver init
+ * for our exclusive use by the telemetry IOCTL.
+ *
+ * Returns the plane pointer, or NULL if not found (should not happen on RPi4).
+ */
+struct drm_plane *vc4_get_telemetry_plane(struct drm_device *dev)
+{
+	struct drm_plane *plane;
+	int idx = 0;
+
+	drm_for_each_plane(plane, dev) {
+		if (plane->type == DRM_PLANE_TYPE_OVERLAY &&
+		    idx++ == VC4_TELEMETRY_PLANE_INDEX)
+			return plane;
+	}
+	return NULL;
+}
+EXPORT_SYMBOL_GPL(vc4_get_telemetry_plane);

diff --git a/drivers/gpu/drm/vc4/vc4_telemetry.c b/drivers/gpu/drm/vc4/vc4_telemetry.c
new file mode 100644
index 0000000..5566778
--- /dev/null
+++ b/drivers/gpu/drm/vc4/vc4_telemetry.c
@@ -0,0 +1,198 @@
+// SPDX-License-Identifier: GPL-2.0-only
+/*
+ * vc4_telemetry.c  —  DRM_IOCTL_VC4_TELEMETRY_OVERLAY implementation
+ *
+ * Issue 5 & 6: Provides a reserved secondary overlay plane and a custom
+ * IOCTL that lets the userspace orchestrator atomically update that plane
+ * with a pre-rendered HUD framebuffer + sensor telemetry metadata.
+ *
+ * Flow:
+ *   Userspace allocates a DUMB buffer, renders text into it (ARGB8888),
+ *   creates a DRM FB from it, then calls this IOCTL with:
+ *     - fb_handle : the DRM FB object ID
+ *     - x_pos, y_pos, width, height : placement on screen
+ *     - accel_x/y/z, pitch_mdeg, roll_mdeg : raw IMU data (logged to
+ *       kernel ring buffer for debugging via dmesg)
+ *     - text[] : human-readable string (also logged)
+ *
+ * The IOCTL finds our reserved overlay plane and does a non-blocking
+ * atomic commit to display the HUD at the requested position.
+ */
+
+#include <drm/drm_atomic.h>
+#include <drm/drm_atomic_helper.h>
+#include <drm/drm_crtc.h>
+#include <drm/drm_file.h>
+#include <drm/drm_fourcc.h>
+#include <drm/drm_framebuffer.h>
+#include <drm/drm_gem.h>
+#include <drm/drm_plane.h>
+#include <drm/drm_plane_helper.h>
+#include <linux/dma-buf.h>
+#include <linux/slab.h>
+#include <uapi/drm/telemetry_uapi.h>
+
+#include "vc4_drv.h"
+
+/* Forward declaration from vc4_plane.c */
+struct drm_plane *vc4_get_telemetry_plane(struct drm_device *dev);
+
+/*
+ * vc4_telemetry_overlay_ioctl - Main IOCTL handler
+ *
+ * Called when userspace issues:
+ *   ioctl(drm_fd, DRM_IOCTL_VC4_TELEMETRY_OVERLAY, &overlay_data);
+ *
+ * @dev       : DRM device (vc4)
+ * @data      : pointer to struct drm_vc4_telemetry_overlay (kernel copy)
+ * @file_priv : DRM file context of the calling process
+ *
+ * Returns 0 on success, negative errno on failure.
+ */
+int vc4_telemetry_overlay_ioctl(struct drm_device *dev, void *data,
+				struct drm_file *file_priv)
+{
+	struct drm_vc4_telemetry_overlay *args = data;
+	struct drm_plane              *plane;
+	struct drm_framebuffer        *fb;
+	struct drm_atomic_state       *state;
+	struct drm_plane_state        *plane_state;
+	struct drm_crtc               *crtc = NULL;
+	struct drm_crtc_state         *crtc_state;
+	struct drm_modeset_acquire_ctx ctx;
+	int ret;
+
+	/* ------------------------------------------------------------------ */
+	/* 1. Null-terminate the text string (defensive; kernel copy is safe)  */
+	args->text[VC4_TELEMETRY_TEXT_LEN - 1] = '\0';
+
+	/* ------------------------------------------------------------------ */
+	/* 2. Log incoming telemetry to the kernel ring buffer (visible via    */
+	/*    dmesg on the Pi — useful for debugging Issue 12 stress test)     */
+	dev_dbg(dev->dev,
+		"vc4_telemetry: accel=(%d,%d,%d)mg pitch=%dmdeg roll=%dmdeg "
+		"pos=(%u,%u) size=(%ux%u) text=\"%s\"\n",
+		args->accel_x_mg, args->accel_y_mg, args->accel_z_mg,
+		args->pitch_mdeg, args->roll_mdeg,
+		args->x_pos, args->y_pos,
+		args->width, args->height,
+		args->text);
+
+	/* ------------------------------------------------------------------ */
+	/* 3. Look up the DRM framebuffer from the handle provided by          */
+	/*    userspace. drm_framebuffer_lookup() increments the reference     */
+	/*    count; we must call drm_framebuffer_put() before returning.      */
+	fb = drm_framebuffer_lookup(dev, file_priv, args->fb_handle);
+	if (!fb) {
+		dev_err(dev->dev,
+			"vc4_telemetry: invalid framebuffer handle %u\n",
+			args->fb_handle);
+		return -ENOENT;
+	}
+
+	/* ------------------------------------------------------------------ */
+	/* 4. Basic sanity checks on the requested dimensions                  */
+	if (args->width == 0 || args->height == 0 ||
+	    args->width  > fb->width  ||
+	    args->height > fb->height) {
+		dev_err(dev->dev,
+			"vc4_telemetry: invalid overlay dimensions %ux%u "
+			"(fb is %ux%u)\n",
+			args->width, args->height, fb->width, fb->height);
+		ret = -EINVAL;
+		goto err_put_fb;
+	}
+
+	/* ------------------------------------------------------------------ */
+	/* 5. Find the reserved telemetry overlay plane (index 1 in vc4's     */
+	/*    plane list, the first DRM_PLANE_TYPE_OVERLAY plane).             */
+	plane = vc4_get_telemetry_plane(dev);
+	if (!plane) {
+		dev_err(dev->dev,
+			"vc4_telemetry: telemetry overlay plane not found\n");
+		ret = -ENODEV;
+		goto err_put_fb;
+	}
+
+	/* ------------------------------------------------------------------ */
+	/* 6. Find the CRTC this plane is associated with (the active display  */
+	/*    head — on RPi4 there is typically one HDMI CRTC active).         */
+	drm_for_each_crtc(crtc, dev) {
+		if (crtc->state && crtc->state->active)
+			break;
+		crtc = NULL;
+	}
+	if (!crtc) {
+		dev_err(dev->dev, "vc4_telemetry: no active CRTC found\n");
+		ret = -ENODEV;
+		goto err_put_fb;
+	}
+
+	/* ------------------------------------------------------------------ */
+	/* 7. Build an atomic state update.                                    */
+	/*    We use the non-blocking atomic path so this IOCTL returns        */
+	/*    immediately without waiting for the next vblank.                 */
+	drm_modeset_acquire_init(&ctx, DRM_MODESET_ACQUIRE_INTERRUPTIBLE);
+
+retry:
+	state = drm_atomic_state_alloc(dev);
+	if (!state) {
+		ret = -ENOMEM;
+		goto err_acquire_ctx;
+	}
+	state->acquire_ctx = &ctx;
+
+	/* Get the current plane state and duplicate it for modification */
+	plane_state = drm_atomic_get_plane_state(state, plane);
+	if (IS_ERR(plane_state)) {
+		ret = PTR_ERR(plane_state);
+		if (ret == -EDEADLK) {
+			drm_atomic_state_put(state);
+			ret = drm_modeset_backoff(&ctx);
+			if (!ret)
+				goto retry;
+		}
+		goto err_put_state;
+	}
+
+	/* Get CRTC state so the atomic commit is aware of the display mode */
+	crtc_state = drm_atomic_get_crtc_state(state, crtc);
+	if (IS_ERR(crtc_state)) {
+		ret = PTR_ERR(crtc_state);
+		goto err_put_state;
+	}
+
+	/* Configure the overlay plane: which FB, where, and how big */
+	plane_state->crtc    = crtc;
+	plane_state->fb      = fb;
+	plane_state->crtc_x  = (int32_t)args->x_pos;
+	plane_state->crtc_y  = (int32_t)args->y_pos;
+	plane_state->crtc_w  = args->width;
+	plane_state->crtc_h  = args->height;
+	/* src coordinates are in 16.16 fixed point; use the full FB source */
+	plane_state->src_x   = 0;
+	plane_state->src_y   = 0;
+	plane_state->src_w   = args->width  << 16;
+	plane_state->src_h   = args->height << 16;
+
+	drm_framebuffer_get(fb); /* atomic commit takes a reference */
+
+	/* ------------------------------------------------------------------ */
+	/* 8. Commit — DRM_MODE_ATOMIC_NONBLOCK so the IOCTL returns fast.    */
+	/*    The hardware flip happens at the next vblank boundary.           */
+	ret = drm_atomic_commit(state);
+	if (ret == -EDEADLK) {
+		drm_atomic_state_put(state);
+		ret = drm_modeset_backoff(&ctx);
+		if (!ret)
+			goto retry;
+	}
+
+err_put_state:
+	drm_atomic_state_put(state);
+err_acquire_ctx:
+	drm_modeset_drop_locks(&ctx);
+	drm_modeset_acquire_fini(&ctx);
+err_put_fb:
+	drm_framebuffer_put(fb);
+	return ret;
+}
