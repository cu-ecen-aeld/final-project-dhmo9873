 drivers/gpu/drm/vc4/vc4_drv.c         |  11 +-
 drivers/gpu/drm/vc4/vc4_drv.h         |  15 ++
 drivers/gpu/drm/vc4/vc4_plane.c       |  22 ++
 drivers/gpu/drm/vc4/vc4_telemetry.c   | 198 +++++++++++++++++++++++++
 include/uapi/drm/vc4_drm.h            |  28 ++++
---

