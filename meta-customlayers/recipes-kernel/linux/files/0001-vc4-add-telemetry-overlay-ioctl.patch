diff --git a/drivers/gpu/drm/vc4/vc4_drv.h b/drivers/gpu/drm/vc4/vc4_drv.h
index aabbcc0..2233445 100644
--- a/drivers/gpu/drm/vc4/vc4_drv.h
+++ b/drivers/gpu/drm/vc4/vc4_drv.h
@@ -1,6 +1,7 @@
 /* SPDX-License-Identifier: GPL-2.0-only */
 
 #include <uapi/drm/vc4_drm.h>
+#include <uapi/drm/telemetry_uapi.h>
 
 /* --- existing content unchanged --- */
 
+/* vc4_telemetry.c exports */
+int vc4_telemetry_overlay_ioctl(struct drm_device *dev, void *data,
+				struct drm_file *file_priv);
+
+/*
+ * Index of the plane we reserve for the telemetry overlay.
+ * vc4/HVS on RPi4 has 8 hardware planes (indices 0-7).
+ * Plane 0 is always the primary (desktop/framebuffer).
+ * We reserve plane index 1 for our telemetry HUD.
+ * All other overlay planes (2-7) remain available to compositors.
+ */
+#define VC4_TELEMETRY_PLANE_INDEX  1

diff --git a/include/uapi/drm/telemetry_uapi.h b/include/uapi/drm/telemetry_uapi.h
new file mode 100644
index 0000000..aaabbcc
--- /dev/null
+++ b/include/uapi/drm/telemetry_uapi.h
@@ -0,0 +1,50 @@
+/* SPDX-License-Identifier: GPL-2.0+ WITH Linux-syscall-note */
+/*
+ * telemetry_uapi.h  -  vc4 Telemetry Overlay IOCTL UAPI
+ *
+ * This is exposed to userspace as part of the vc4 DRM driver extension.
+ * Userspace must #include <drm/telemetry_uapi.h> (or use the copy in
+ * the orchestrator's include/ directory).
+ */
+#ifndef _UAPI_DRM_TELEMETRY_H
+#define _UAPI_DRM_TELEMETRY_H
+
+#include <linux/ioctl.h>
+#include <linux/types.h>
+
+#define VC4_TELEMETRY_TEXT_LEN  64
+
+struct drm_vc4_telemetry_overlay {
+	__s32 accel_x_mg;
+	__s32 accel_y_mg;
+	__s32 accel_z_mg;
+	__s32 pitch_mdeg;
+	__s32 roll_mdeg;
+	__u32 fb_handle;      /* GEM object handle for the HUD framebuffer */
+	__u32 x_pos;
+	__u32 y_pos;
+	__u32 width;
+	__u32 height;
+	char  text[VC4_TELEMETRY_TEXT_LEN];
+	__u32 flags;
+	__u32 pad[3];
+};
+
+/* Appended to existing vc4 ioctl numbering (last existing = 0x0a) */
+#define DRM_VC4_TELEMETRY_OVERLAY  0x0b
+
+#define DRM_IOCTL_VC4_TELEMETRY_OVERLAY \
+	DRM_IOWR(DRM_COMMAND_BASE + DRM_VC4_TELEMETRY_OVERLAY, \
+		 struct drm_vc4_telemetry_overlay)
+
+#endif /* _UAPI_DRM_TELEMETRY_H */

